// Возвращает остатки товаров на указанных складах на заданную дату.
//
// Параметры:
//   ДатаАктуальности - Дата - момент времени, на который получаются остатки
//   Номенклатура - СправочникСсылка.Номенклатура - номенклатура, для которой запрашиваются остатки
//   Склады - Массив из СправочникСсылка.Склады - список складов, по которым получаются остатки
//
// Возвращаемое значение:
//   Структура:
//     * <КлючСклада> - Число - количество остатков на складе (ключ - строковое представление ссылки на склад без пробелов)
Функция ПолучитьОстаткиПоСкладам(ДатаАктуальности, Номенклатура, Склады) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТоварыОстатки.Склад КАК Склад,
	|	ТоварыОстатки.КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.Товары.Остатки(&ДатаАктуальности, Номенклатура = &Номенклатура И Склад В (&Склады)) КАК ТоварыОстатки";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ДатаАктуальности", ДатаАктуальности);
	Запрос.УстановитьПараметр("Склады", Склады);
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();

	Остатки = Новый Структура;
	
	Пока Выборка.Следующий() Цикл
		КлючСклада = СтрЗаменить(Строка(Выборка.Склад), " ", "");
		Остатки.Вставить(КлючСклада, Выборка.Количество);
	КонецЦикла;
	
	Возврат Остатки;
	
	Сообщить(НСтр("ru = 'Привет мир!'; en = 'Hello world!'; zh = '你好世界!'; es = '¡Hola mundo!'"));

КонецФункции

