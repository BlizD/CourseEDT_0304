// Описание человека.
// 
// Возвращаемое значение:
//  Структура - Описание человека:
// * Имя - Строка - 
// * ДатаРождения - Дата - 
// * Стаж - Число - 
// * Штатный - Булево - 
Функция ОписаниеЧеловека() Экспорт

	Человек = Новый Структура;
	Человек.Вставить("Имя", "Антон");
	Человек.Вставить("ДатаРождения", ТекущаяДата());
	Человек.Вставить("Стаж", 15);
	Человек.Вставить("Штатный", Истина);

	Возврат Человек;

КонецФункции

#КонецОбласти